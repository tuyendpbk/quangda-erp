@model PrintERP.Web.Models.ViewModels.OrderStatusUpdateViewModel
@{
    ViewData["Title"] = "Update Order Status";

    string StatusClass(string status) => status.ToUpperInvariant() switch
    {
        "NEW" => "text-bg-secondary",
        "DESIGN" => "text-bg-primary",
        "PRODUCING" => "text-bg-warning",
        "DONE" => "text-bg-success",
        "DELIVERED" => "bg-primary text-white",
        "CANCELLED" => "text-bg-danger",
        _ => "text-bg-secondary"
    };

    string statusValue = string.IsNullOrWhiteSpace(Model.NewStatus) ? string.Empty : Model.NewStatus.ToUpperInvariant();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start mb-3 gap-2 flex-wrap">
        <div>
            <h2 class="mb-1">Update Order Status</h2>
            <div class="text-muted">SCR-ORD-STS-01</div>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.OrderId">Quay lại chi tiết</a>
    </div>

    <form method="post" asp-action="UpdateStatus" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OrderId" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="card mb-3">
            <div class="card-header">Thông tin tóm tắt đơn hàng</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <small class="text-muted d-block">Mã đơn hàng</small>
                        <strong>@Model.OrderCode</strong>
                    </div>
                    <div class="col-md-4">
                        <small class="text-muted d-block">Khách hàng</small>
                        <span>@Model.CustomerName</span>
                    </div>
                    <div class="col-md-4">
                        <small class="text-muted d-block">Trạng thái hiện tại</small>
                        <span class="badge @StatusClass(Model.CurrentStatus)">@Model.CurrentStatus</span>
                    </div>
                    <div class="col-md-4">
                        <small class="text-muted d-block">Ngày tạo đơn</small>
                        <span>@Model.OrderDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="col-md-4">
                        <small class="text-muted d-block">Ngày giao</small>
                        @if (Model.DeliveryDate.HasValue)
                        {
                            <span class="@(Model.IsOverdue ? "text-danger fw-semibold" : string.Empty)">@Model.DeliveryDate.Value.ToString("dd/MM/yyyy")</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Cập nhật trạng thái</div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="NewStatus" class="form-label">Trạng thái mới</label>
                    <select asp-for="NewStatus" class="form-select" id="new-status-select">
                        <option value="">-- Chọn trạng thái --</option>
                        @foreach (var status in Model.AvailableStatuses)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                    <span asp-validation-for="NewStatus" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Note" class="form-label">Ghi chú</label>
                    <textarea asp-for="Note" class="form-control" rows="4" placeholder="Nhập ghi chú cập nhật trạng thái..."></textarea>
                    <div class="form-text">Nếu chuyển sang CANCELLED, ghi chú là bắt buộc.</div>
                    <span asp-validation-for="Note" class="text-danger"></span>
                </div>

                <div id="status-warning" class="alert alert-warning d-none mb-0" role="alert"></div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Cập nhật trạng thái</button>
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.OrderId">Hủy / Đóng</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const select = document.getElementById('new-status-select');
            const warningBox = document.getElementById('status-warning');
            const currentStatus = '@Model.CurrentStatus'.toUpperCase();
            const hasPayments = '@Model.HasPayments'.toLowerCase() === 'true';
            const hasStockOut = '@Model.HasStockOut'.toLowerCase() === 'true';

            function setWarning(messages) {
                if (!messages.length) {
                    warningBox.classList.add('d-none');
                    warningBox.innerHTML = '';
                    return;
                }

                warningBox.classList.remove('d-none');
                warningBox.innerHTML = `<ul class="mb-0">${messages.map(m => `<li>${m}</li>`).join('')}</ul>`;
            }

            function onStatusChange() {
                const newStatus = (select.value || '').toUpperCase();
                const warnings = [];

                if (newStatus === 'DONE') {
                    if (!hasStockOut) {
                        warnings.push('Đơn chưa có phiếu xuất kho, cần kiểm tra trước khi hoàn tất.');
                    }
                }

                if (newStatus === 'DELIVERED' && currentStatus !== 'DONE') {
                    warnings.push('Đơn chưa ở trạng thái DONE, kiểm tra quyền override trước khi giao hàng.');
                }

                if (newStatus === 'CANCELLED') {
                    warnings.push('Bạn cần nhập lý do hủy đơn.');
                    if (hasPayments) {
                        warnings.push('Đơn đã phát sinh thanh toán. Có thể bị chặn hủy theo rule.');
                    }

                    if (hasStockOut) {
                        warnings.push('Đơn đã phát sinh xuất kho. Có thể bị chặn hủy theo rule.');
                    }
                }

                setWarning(warnings);
            }

            select.addEventListener('change', onStatusChange);
            if ('@statusValue') {
                select.value = '@statusValue';
            }
            onStatusChange();
        })();
    </script>
}
