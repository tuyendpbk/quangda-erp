@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-page py-4 py-md-5">
    <div class="container">
        <div class="row justify-content-center align-items-center g-4">
            <div class="col-lg-5 d-none d-lg-block">
                <div class="brand-panel p-4 p-xl-5">
                    <span class="badge text-bg-light text-primary-emphasis mb-3">QuangDa ERP</span>
                    <h1 class="display-6 fw-bold mb-3">Điều hành nhà in thông minh, trực quan và chính xác.</h1>
                    <p class="mb-4 text-secondary">Theo dõi đơn hàng, doanh thu, công nợ và tiến độ sản xuất chỉ trong một màn hình.</p>
                    <div class="d-grid gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi bi-speedometer2 fs-4 text-primary"></i>
                            <span>Dashboard KPI theo thời gian thực</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi bi-graph-up-arrow fs-4 text-primary"></i>
                            <span>Phân tích doanh thu và dự báo xu hướng</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi bi-shield-lock fs-4 text-primary"></i>
                            <span>Phân quyền và bảo mật theo vai trò</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8 col-lg-5 col-xl-4">
                <div class="card border-0 shadow-lg login-card-modern">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <div class="logo mx-auto mb-3">QD</div>
                            <h2 class="h4 fw-semibold mb-1">Đăng nhập hệ thống</h2>
                            <p class="text-secondary mb-0">Vui lòng xác thực để tiếp tục</p>
                        </div>

                        <form asp-action="Login" asp-controller="Account" method="post" id="loginForm" novalidate>
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(m => m.ReturnUrl)

                            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="Username" class="form-label fw-medium">Tên đăng nhập</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                                    <input asp-for="Username" maxlength="50" autocomplete="username" class="form-control" placeholder="Nhập tên đăng nhập" />
                                </div>
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-medium">Mật khẩu</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                                    <input asp-for="Password" maxlength="255" autocomplete="current-password" class="form-control" placeholder="Nhập mật khẩu" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input asp-for="RememberMe" class="form-check-input" />
                                    <label asp-for="RememberMe" class="form-check-label">Ghi nhớ đăng nhập</label>
                                </div>
                                <span class="small text-secondary">Bảo mật bởi SSL</span>
                            </div>

                            <button type="submit" id="loginButton" class="btn btn-primary btn-lg w-100 rounded-3 fw-semibold">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                            </button>
                        </form>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-center pt-0 pb-4 text-secondary small">
                        © @DateTime.UtcNow.Year QuangDa ERP
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.getElementById('loginForm');
            const button = document.getElementById('loginButton');

            if (form && button) {
                form.addEventListener('submit', () => {
                    button.disabled = true;
                    button.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Đang đăng nhập...';
                });
            }

            const firstError = document.querySelector('.input-validation-error');
            if (firstError) {
                firstError.focus();
            }
        })();
    </script>
}
