@model PrintERP.Web.Models.ViewModels.EmployeeListViewModel
@{
    ViewData["Title"] = "Employee List";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start mb-3 gap-2 flex-wrap">
        <div>
            <h2 class="mb-1">Danh sách nhân viên</h2>
            <div class="text-muted">Hiển thị danh sách tài khoản nhân viên trong hệ thống.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (Model.CanCreateEmployee)
            {
                <a class="btn btn-primary" asp-action="Create">Thêm nhân viên</a>
            }
            @if (Model.CanExport)
            {
                <button type="button" class="btn btn-outline-success" disabled>Xuất Excel</button>
            }
        </div>
    </div>

    @if (ViewBag.ErrorMessage is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (ViewBag.SuccessMessage is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <partial name="_EmployeeFilter" model="Model" />
    <partial name="_EmployeeListSummary" model="Model" />
    <partial name="_EmployeeListTable" model="Model" />
    <partial name="_EmployeeListPagination" model="Model" />
</div>
