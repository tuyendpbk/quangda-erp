@model PrintERP.Web.Models.ViewModels.EmployeeListViewModel
@{
    var pageSizes = new[] { 10, 20, 50, 100 };
    string BuildPageLink(int page)
    {
        return Url.Action("Index", new
        {
            Model.Filter.Keyword,
            Model.Filter.Department,
            Model.Filter.Position,
            Model.Filter.RoleId,
            Model.Filter.Status,
            Model.Filter.HireDateFrom,
            Model.Filter.HireDateTo,
            Model.Filter.SortBy,
            Model.Filter.SortDirection,
            Page = page,
            Model.Filter.PageSize
        }) ?? "#";
    }
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
        <input type="hidden" name="Keyword" value="@Model.Filter.Keyword" />
        <input type="hidden" name="Department" value="@Model.Filter.Department" />
        <input type="hidden" name="Position" value="@Model.Filter.Position" />
        <input type="hidden" name="RoleId" value="@Model.Filter.RoleId" />
        <input type="hidden" name="Status" value="@Model.Filter.Status" />
        <input type="hidden" name="HireDateFrom" value="@Model.Filter.HireDateFrom?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="HireDateTo" value="@Model.Filter.HireDateTo?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="SortBy" value="@Model.Filter.SortBy" />
        <input type="hidden" name="SortDirection" value="@Model.Filter.SortDirection" />
        <input type="hidden" name="Page" value="1" />

        <label class="form-label mb-0">Số dòng/trang</label>
        <select class="form-select form-select-sm" style="width: 88px;" name="PageSize" onchange="this.form.submit()">
            @foreach (var size in pageSizes)
            {
                <option value="@size" selected="@(Model.Filter.PageSize == size)">@size</option>
            }
        </select>
    </form>

    <nav>
        <ul class="pagination mb-0">
            <li class="page-item @(Model.Filter.Page <= 1 ? "disabled" : string.Empty)"><a class="page-link" href="@BuildPageLink(Model.Filter.Page - 1)">‹</a></li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.Filter.Page == i ? "active" : string.Empty)"><a class="page-link" href="@BuildPageLink(i)">@i</a></li>
            }
            <li class="page-item @(Model.Filter.Page >= Model.TotalPages ? "disabled" : string.Empty)"><a class="page-link" href="@BuildPageLink(Model.Filter.Page + 1)">›</a></li>
        </ul>
    </nav>
</div>
