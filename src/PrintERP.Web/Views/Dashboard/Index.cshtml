@model PrintERP.Web.Models.ViewModels.DashboardViewModel
@using PrintERP.Web.Models.ViewModels
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "N/A";
    var errorMessage = TempData["DashboardError"] as string;
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name;
}

<section class="dashboard-page py-4 py-lg-5">
    <div class="container-fluid px-lg-4">
        <div class="card border-0 shadow-sm overflow-hidden mb-4 dashboard-header-card">
            <div class="card-body p-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <p class="text-uppercase text-primary fw-semibold small mb-2">Operations Center</p>
                    <h1 class="h3 fw-bold mb-1">Dashboard vận hành</h1>
                    <p class="text-secondary mb-0">Xin chào <strong>@fullName</strong> · Vai trò: <strong>@role</strong></p>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                    </button>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger border-0 shadow-sm" role="alert">@errorMessage</div>
        }

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <form asp-action="Index" asp-controller="Dashboard" method="get" class="row g-3 align-items-end">
                    <div class="col-12 col-md-4 col-xl-3">
                        <label asp-for="Filter.PeriodType" class="form-label fw-medium">Thời gian</label>
                        <select asp-for="Filter.PeriodType" id="periodTypeSelect" class="form-select">
                            <option value="@DashboardPeriodTypes.Today">Hôm nay</option>
                            <option value="@DashboardPeriodTypes.Last7Days">7 ngày gần nhất</option>
                            <option value="@DashboardPeriodTypes.Last30Days">30 ngày gần nhất</option>
                            <option value="@DashboardPeriodTypes.ThisMonth">Tháng này</option>
                            <option value="@DashboardPeriodTypes.ThisQuarter">Quý này</option>
                            <option value="@DashboardPeriodTypes.ThisYear">Năm nay</option>
                            <option value="@DashboardPeriodTypes.Custom">Tùy chọn</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-4 col-xl-3 custom-range-field">
                        <label asp-for="Filter.FromDate" class="form-label fw-medium">Từ ngày</label>
                        <input asp-for="Filter.FromDate" type="date" class="form-control" />
                        <span asp-validation-for="Filter.FromDate" class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-md-4 col-xl-3 custom-range-field">
                        <label asp-for="Filter.ToDate" class="form-label fw-medium">Đến ngày</label>
                        <input asp-for="Filter.ToDate" type="date" class="form-control" />
                        <span asp-validation-for="Filter.ToDate" class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-xl-3">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-funnel me-2"></i>Áp dụng bộ lọc
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6 col-xl-3"><a class="text-decoration-none" href="/Orders/Index"> <div class="card border-0 shadow-sm h-100 kpi-card"><div class="card-body"><p class="small text-secondary mb-1">Tổng đơn hàng</p><p class="h4 mb-0">@Model.TotalOrders</p></div></div></a></div>
            <div class="col-12 col-sm-6 col-xl-3"><a class="text-decoration-none" href="/Orders/Index?status=NEW"> <div class="card border-0 shadow-sm h-100 kpi-card"><div class="card-body"><p class="small text-secondary mb-1">Đơn hàng mới</p><p class="h4 mb-0">@Model.NewOrders</p></div></div></a></div>
            <div class="col-12 col-sm-6 col-xl-3"><a class="text-decoration-none" href="/Orders/Index?status=PRODUCING"> <div class="card border-0 shadow-sm h-100 kpi-card"><div class="card-body"><p class="small text-secondary mb-1">Đang sản xuất</p><p class="h4 mb-0">@Model.ProducingOrders</p></div></div></a></div>
            <div class="col-12 col-sm-6 col-xl-3"><a class="text-decoration-none" href="/Orders/Index?nearDue=true"> <div class="card border-0 shadow-sm h-100 kpi-card"><div class="card-body"><p class="small text-secondary mb-1">Đơn sắp giao</p><p class="h4 mb-0">@Model.NearDueOrders</p></div></div></a></div>
            <div class="col-12 col-sm-6 col-xl-3"><a class="text-decoration-none" href="/Orders/Index?isOverdue=true"> <div class="card border-0 shadow-sm h-100 kpi-card kpi-card-danger"><div class="card-body"><p class="small text-secondary mb-1">Đơn trễ hạn</p><p class="h4 mb-0">@Model.OverdueOrders</p></div></div></a></div>
            <div class="col-12 col-sm-6 col-xl-3"><a class="text-decoration-none" href="/Reports/Revenue"> <div class="card border-0 shadow-sm h-100 kpi-card"><div class="card-body"><p class="small text-secondary mb-1">Doanh thu</p><p class="h4 mb-0">@Model.Revenue.ToString("N0") đ</p></div></div></a></div>
            <div class="col-12 col-sm-6 col-xl-3"><div class="card border-0 shadow-sm h-100 kpi-card"><div class="card-body"><p class="small text-secondary mb-1">Đã thanh toán</p><p class="h4 mb-0">@Model.PaidAmount.ToString("N0") đ</p></div></div></div>
            <div class="col-12 col-sm-6 col-xl-3"><div class="card border-0 shadow-sm h-100 kpi-card"><div class="card-body"><p class="small text-secondary mb-1">Công nợ còn lại</p><p class="h4 mb-0">@Model.RemainingDebt.ToString("N0") đ</p></div></div></div>
            <div class="col-12 col-sm-6 col-xl-3"><a class="text-decoration-none" href="/Materials/Index?lowStock=true"> <div class="card border-0 shadow-sm h-100 kpi-card kpi-card-danger"><div class="card-body"><p class="small text-secondary mb-1">Vật tư sắp hết</p><p class="h4 mb-0">@Model.LowStockMaterials</p></div></div></a></div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-lg-6"><div class="card border-0 shadow-sm h-100"><div class="card-body p-4"><h2 class="h5 fw-semibold mb-3">Biểu đồ doanh thu</h2>@if (Model.RevenueChart.Count == 0){<p class="text-secondary mb-0">Không có dữ liệu</p>} else {<canvas id="revenueChartCanvas" height="220"></canvas>}</div></div></div>
            <div class="col-12 col-lg-6"><div class="card border-0 shadow-sm h-100"><div class="card-body p-4"><h2 class="h5 fw-semibold mb-3">Trạng thái đơn hàng</h2>@if (Model.OrderStatusChart.Count == 0){<p class="text-secondary mb-0">Không có dữ liệu</p>} else {<canvas id="orderStatusChartCanvas" height="220"></canvas>}</div></div></div>
            @if (Model.ShowPaymentBlocks){<div class="col-12 col-lg-6"><div class="card border-0 shadow-sm h-100"><div class="card-body p-4"><h2 class="h5 fw-semibold mb-3">Tình hình thanh toán</h2>@foreach (var item in Model.PaymentChart){<ul class="list-group list-group-flush"><li class="list-group-item d-flex justify-content-between px-0"><span>Tổng đơn</span><strong>@item.TotalOrderAmount.ToString("N0") đ</strong></li><li class="list-group-item d-flex justify-content-between px-0"><span>Đã thanh toán</span><strong>@item.PaidAmount.ToString("N0") đ</strong></li><li class="list-group-item d-flex justify-content-between px-0"><span>Còn nợ</span><strong>@item.RemainingDebt.ToString("N0") đ</strong></li></ul>}</div></div></div>}
            @if (Model.ShowForecastBlock){<div class="col-12 col-lg-6"><div class="card border-0 shadow-sm h-100 forecast-card"><div class="card-body p-4 d-flex flex-column justify-content-center"><h2 class="h5 fw-semibold mb-2">Dự báo doanh thu kỳ tới</h2><p class="display-6 fw-bold text-primary mb-0">@(Model.ForecastRevenue?.ToString("N0") ?? "0") đ</p></div></div></div>}
        </div>

        <div class="card border-0 shadow-sm mb-3"><div class="card-body p-0"><div class="px-4 pt-4 pb-2"><h2 class="h5 fw-semibold mb-0">Đơn hàng mới nhất</h2></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Mã đơn</th><th>Ngày tạo</th><th>Khách hàng</th><th>Hạn giao</th><th>Trạng thái</th><th class="text-end">Tổng tiền</th></tr></thead><tbody>@if (Model.RecentOrders.Count == 0){<tr><td colspan="6" class="text-center text-secondary py-4">Không có dữ liệu</td></tr>} else {@foreach (var item in Model.RecentOrders){<tr><td><a href="/Orders/Details/@item.Id" class="fw-semibold link-primary">@item.OrderCode</a></td><td>@item.OrderDate.ToString("dd/MM/yyyy")</td><td>@item.CustomerName</td><td>@item.DeliveryDate.ToString("dd/MM/yyyy")</td><td>@item.Status</td><td class="text-end">@item.TotalAmount.ToString("N0")</td></tr>}}</tbody></table></div></div></div>

        <div class="card border-0 shadow-sm mb-3"><div class="card-body p-0"><div class="px-4 pt-4 pb-2"><h2 class="h5 fw-semibold mb-0">Đơn sắp giao / trễ hạn</h2></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Mã đơn</th><th>Khách hàng</th><th>Ngày giao</th><th>Trạng thái</th><th>Phụ trách</th><th>Cảnh báo</th></tr></thead><tbody>@if (Model.DueOrders.Count == 0){<tr><td colspan="6" class="text-center text-secondary py-4">Không có dữ liệu</td></tr>} else {@foreach (var item in Model.DueOrders){var warningClass = item.WarningLevel == "OVERDUE" ? "text-danger fw-semibold" : item.WarningLevel == "NEAR_DUE" ? "text-warning-emphasis fw-semibold" : string.Empty;<tr><td><a href="/Orders/Details/@item.Id" class="fw-semibold link-primary">@item.OrderCode</a></td><td>@item.CustomerName</td><td>@item.DeliveryDate.ToString("dd/MM/yyyy")</td><td>@item.Status</td><td>@item.Owner</td><td class="@warningClass">@item.WarningLevel</td></tr>}}</tbody></table></div></div></div>

        <div class="card border-0 shadow-sm mb-3"><div class="card-body p-0"><div class="px-4 pt-4 pb-2"><h2 class="h5 fw-semibold mb-0">Vật tư sắp hết</h2></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Mã vật tư</th><th>Tên</th><th>Nhóm</th><th>Tồn hiện tại</th><th>Tồn tối thiểu</th><th>Đơn vị</th></tr></thead><tbody>@if (Model.LowStockItems.Count == 0){<tr><td colspan="6" class="text-center text-secondary py-4">Không có dữ liệu</td></tr>} else {@foreach (var item in Model.LowStockItems){<tr><td><a href="/Materials/Details/@item.Id" class="fw-semibold link-primary">@item.MaterialCode</a></td><td>@item.MaterialName</td><td>@item.GroupName</td><td>@item.CurrentStock</td><td>@item.MinStockLevel</td><td>@item.Unit</td></tr>}}</tbody></table></div></div></div>

        @if (Model.ShowPaymentBlocks){<div class="card border-0 shadow-sm mb-3"><div class="card-body p-0"><div class="px-4 pt-4 pb-2"><h2 class="h5 fw-semibold mb-0">Thanh toán gần đây</h2></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Ngày</th><th>Mã đơn</th><th>Khách hàng</th><th class="text-end">Số tiền</th><th>Phương thức</th></tr></thead><tbody>@if (Model.RecentPayments.Count == 0){<tr><td colspan="5" class="text-center text-secondary py-4">Không có dữ liệu</td></tr>} else {@foreach (var item in Model.RecentPayments){<tr><td>@item.PaymentDate.ToString("dd/MM/yyyy")</td><td>@item.OrderCode</td><td>@item.CustomerName</td><td class="text-end">@item.Amount.ToString("N0")</td><td>@item.Method</td></tr>}}</tbody></table></div></div></div>}

        @if (Model.ShowTopCustomers){<div class="card border-0 shadow-sm mb-3"><div class="card-body p-0"><div class="px-4 pt-4 pb-2"><h2 class="h5 fw-semibold mb-0">Top khách hàng</h2></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Khách hàng</th><th>Số đơn</th><th class="text-end">Doanh thu</th><th class="text-end">Công nợ</th></tr></thead><tbody>@if (Model.TopCustomers.Count == 0){<tr><td colspan="4" class="text-center text-secondary py-4">Không có dữ liệu</td></tr>} else {@foreach (var item in Model.TopCustomers){<tr><td>@item.CustomerName</td><td>@item.OrderCount</td><td class="text-end">@item.Revenue.ToString("N0")</td><td class="text-end">@item.RemainingDebt.ToString("N0")</td></tr>}}</tbody></table></div></div></div>}
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js" integrity="sha384-Gtv+P7D6L7dFfY2TbK7jlza8+Vx4cxvQ4/AfY4qRxaL3V7mgQlkvfCJWx0hG5n5x" crossorigin="anonymous"></script>
    <script>
        const periodTypeSelect = document.getElementById('periodTypeSelect');
        const customFields = document.querySelectorAll('.custom-range-field');
        const formatCurrency = (value) =>
            new Intl.NumberFormat('vi-VN', { maximumFractionDigits: 0 }).format(value) + ' đ';

        const updateCustomRangeVisibility = () => {
            const isCustom = periodTypeSelect.value === '@DashboardPeriodTypes.Custom';
            customFields.forEach(x => x.classList.toggle('d-none', !isCustom));
        };

        periodTypeSelect.addEventListener('change', updateCustomRangeVisibility);
        updateCustomRangeVisibility();

        const revenueChartCanvas = document.getElementById('revenueChartCanvas');
        if (revenueChartCanvas) {
            const revenueData = @Html.Raw(JsonSerializer.Serialize(Model.RevenueChart));
            new Chart(revenueChartCanvas, {
                type: 'line',
                data: {
                    labels: revenueData.map(item => item.label),
                    datasets: [{
                        label: 'Doanh thu',
                        data: revenueData.map(item => item.revenue),
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.12)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 4,
                        pointHoverRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: (context) => `Doanh thu: ${formatCurrency(context.parsed.y ?? 0)}`
                            }
                        }
                    },
                    scales: {
                        y: {
                            ticks: {
                                callback: (value) => formatCurrency(value)
                            }
                        }
                    }
                }
            });
        }

        const orderStatusChartCanvas = document.getElementById('orderStatusChartCanvas');
        if (orderStatusChartCanvas) {
            const orderStatusData = @Html.Raw(JsonSerializer.Serialize(Model.OrderStatusChart));
            new Chart(orderStatusChartCanvas, {
                type: 'doughnut',
                data: {
                    labels: orderStatusData.map(item => item.status),
                    datasets: [{
                        label: 'Số lượng đơn',
                        data: orderStatusData.map(item => item.count),
                        backgroundColor: [
                            '#0d6efd',
                            '#20c997',
                            '#ffc107',
                            '#dc3545',
                            '#6f42c1',
                            '#fd7e14'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        }
    </script>
}
